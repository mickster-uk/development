{
  "name": "bot-tester",
  "version": "1.0.0",
  "description": "An advanced bot testing application with three-bot evaluation system",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 90000
  },
  "build": {
    "appId": "com.bottester.desktop",
    "productName": "Bot Tester",
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

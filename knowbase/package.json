{
  "name": "knowbase",
  "version": "1.0.7",
  "description": "A side-panel knowledge base and markdown reader built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "ELECTRON_RUN_AS_NODE= ELECTRON_ENABLE_LOGGING=1 electron .",
    "build-icons": "node scripts/generate-icons.js",
    "prebuild": "npm version patch --no-git-tag-version",
    "build": "electron-builder --publish never",
    "postbuild": "APP=$(find dist -name '*.app' -maxdepth 3 -print -quit) && APP_NAME=$(basename \"$APP\") && rm -rf \"/Applications/$APP_NAME\" && cp -r \"$APP\" \"/Applications/$APP_NAME\" && { test ! -e \"$HOME/Desktop/$APP_NAME\" && test ! -L \"$HOME/Desktop/$APP_NAME\" && ln -s \"/Applications/$APP_NAME\" \"$HOME/Desktop/$APP_NAME\" || true; }",
    "prebuild:mac": "npm version patch --no-git-tag-version",
    "build:mac": "electron-builder --mac --publish never",
    "postbuild:mac": "APP=$(find dist -name '*.app' -maxdepth 3 -print -quit) && APP_NAME=$(basename \"$APP\") && rm -rf \"/Applications/$APP_NAME\" && cp -r \"$APP\" \"/Applications/$APP_NAME\" && { test ! -e \"$HOME/Desktop/$APP_NAME\" && test ! -L \"$HOME/Desktop/$APP_NAME\" && ln -s \"/Applications/$APP_NAME\" \"$HOME/Desktop/$APP_NAME\" || true; }",
    "prebuild:win": "npm version patch --no-git-tag-version",
    "build:win": "electron-builder --win --publish never",
    "prebuild:linux": "npm version patch --no-git-tag-version",
    "build:linux": "electron-builder --linux --publish never",
    "test": "jest --testPathPatterns=lib/",
    "test:ci": "jest --testPathPatterns=lib/ --ci --json --outputFile=../../../Documents/knowbase/apps/knowbase/tests/unit/results.json"
  },
  "keywords": [
    "electron",
    "markdown",
    "reader"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.4.2",
    "playwright-core": "^1.60.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^4.3.0",
    "mermaid": "^11.15.0"
  },
  "build": {
    "appId": "com.knowbase.app",
    "productName": "Knowbase",
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}

{
  "name": "CalendarAI",
  "version": "1.0.0",
  "description": "Google Calendar year plan viewer with Ollama AI search",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "googleapis": "^173.0.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.calendarai.desktop",
    "productName": "CalendarAI",
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
